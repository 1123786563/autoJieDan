# =============================================================================
# Automaton + Nanobot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Interagent Shared Secret
# -----------------------------------------------------------------------------
# This secret is used for HMAC authentication between Automaton and Nanobot
# Generate with: openssl rand -hex 32
INTERAGENT_SECRET=your-shared-secret-here

# -----------------------------------------------------------------------------
# Automaton Configuration
# -----------------------------------------------------------------------------
# Image version (optional, defaults to 'latest')
AUTOMATON_VERSION=latest

# Port configuration (optional, defaults shown)
AUTOMATON_HTTP_PORT=18790
AUTOMATON_WS_PORT=18791

# Optional: Path to custom config file
# AUTOMATON_CONFIG_PATH=./automaton/config.yml

# -----------------------------------------------------------------------------
# Nanobot Configuration
# -----------------------------------------------------------------------------
# Image version (optional, defaults to 'latest')
NANOBOT_VERSION=latest

# Port configuration (optional, defaults shown)
# Note: Nanobot's internal port 18791 is mapped to host port 18792
NANOBOT_HTTP_PORT=18792

# Optional: Path to custom config file
# NANOBOT_CONFIG_PATH=./nanobot/config.yml

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# OpenAI (used by both services)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (optional, alternative LLM provider)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Nanobot LLM provider selection
# Options: openai, anthropic, azure, etc.
NANOBOT_LLM_PROVIDER=openai
NANOBOT_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# Messaging Platform Configuration (Optional)
# -----------------------------------------------------------------------------
# Telegram Bot Token
# NANOBOT_TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Slack Bot Token
# NANOBOT_SLACK_TOKEN=xoxb-your-slack-bot-token

# DingTalk App Key
# NANOBOT_DINGTALK_APP_KEY=your-dingtalk-app-key

# Lark/Feishu App ID
# NANOBOT_LARK_APP_ID=your-lark-app-id

# -----------------------------------------------------------------------------
# Blockchain Configuration (Optional - for Automaton)
# -----------------------------------------------------------------------------
# Private key for Automaton's wallet (DO NOT COMMIT!)
# AUTOMATON_PRIVATE_KEY=0x-your-private-key

# Base RPC URL (optional, defaults to public RPC)
# BASE_RPC_URL=https://mainnet.base.org

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable interagent communication
INTERAGENT_ENABLED=true

# Logging level (debug, info, warn, error)
# LOG_LEVEL=info
