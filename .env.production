# =============================================================================
# Production Environment Configuration
# =============================================================================
# WARNING: This is a template. Update with actual production values before deploying.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Interagent Shared Secret
# -----------------------------------------------------------------------------
# SECURITY: Must be set via environment or secret manager before deployment
# Generate with: openssl rand -hex 32
INTERAGENT_SECRET=

# -----------------------------------------------------------------------------
# Automaton Configuration
# -----------------------------------------------------------------------------
AUTOMATON_VERSION=v1.0.0
AUTOMATON_HTTP_PORT=10790
AUTOMATON_WS_PORT=10791

# -----------------------------------------------------------------------------
# Nanobot Configuration
# -----------------------------------------------------------------------------
NANOBOT_VERSION=v1.0.0
NANOBOT_HTTP_PORT=10792

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=${OPENAI_API_KEY:-}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
NANOBOT_LLM_PROVIDER=openai
NANOBOT_API_KEY=${OPENAI_API_KEY:-}

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
INTERAGENT_ENABLED=true
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD:-$(openssl rand -hex 16)}

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
ELASTICSEARCH_PORT=9200
LOGSTASH_TCP_PORT=5000
KIBANA_PORT=5601
